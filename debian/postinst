#!/bin/sh

set -e

case "$1" in
  configure|abort-upgrade|abort-deconfigure|abort-remove)
    # Handle sbctl.service
    deb-systemd-helper unmask 'sbctl.service' >/dev/null || true
    if deb-systemd-helper --quiet was-enabled 'sbctl.service'; then
      deb-systemd-helper enable 'sbctl.service' >/dev/null || true
    else
      deb-systemd-helper update-state 'sbctl.service' >/dev/null || true
    fi

    # Reload systemd and start or restart services
    if [ -d /run/systemd/system ]; then
      systemctl --system daemon-reload >/dev/null || true
      if [ -n "$2" ]; then
        _dh_action=restart
      else
        _dh_action=start
      fi
      deb-systemd-invoke $_dh_action 'sbctl.service' >/dev/null || true
    fi
    ;;
    *) echo "Unsupported option $1" ; exit 1
esac
